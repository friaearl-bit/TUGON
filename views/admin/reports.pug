    // ============ CHARTS ROW 1 ============
    .dashboard-grid
      .grid-item.span-2
        .card
          .card-header
            h5 Complaints by Status
          .card-body
            .chart-container
              canvas#statusChart
      .grid-item.span-2
        .card
          .card-header
            h5 Complaints by Priority
          .card-body
            .chart-container
              canvas#priorityChart

      // ============ CHARTS ROW 2 ============
      .grid-item.span-2
        .card
          .card-header
            h5 Department Workload
          .card-body
            .chart-container
              canvas#departmentChart
      .grid-item.span-2
        .card
          .card-header
            h5 Complaints by Category
          .card-body
            .chart-container
              canvas#categoryChart

      // ============ CHARTS ROW 3 ============
      .grid-item.full-width
        .card
          .card-header
            h5 Monthly Complaint Trend
          .card-body
            .chart-container
              canvas#monthlyChart

    // ============ CHARTS ROW 4 ============
      .grid-item
        .card
          .card-header
            h5 Staff Performance
          .card-body
            .chart-container
              canvas#staffChart
      .grid-item
        .card
          .card-header
            h5 Resolution Time Metrics
          .card-body
            .metrics-grid
              .metric
                .metric-value 0h
                .metric-label Average
              .metric
                .metric-value 0h
                .metric-label Fastest
              .metric
                .metric-value 0h
                .metric-label Slowest
              .metric
                .metric-value 0
                .metric-label Total Resolved

    // ============ ERROR DISPLAY ============
    .alert.alert-error#reportsError(style="display: none;")

  script(src="/js/chart.umd.min.js")
  script(src="/js/reports.js" type="module")
  include ../partials/footer