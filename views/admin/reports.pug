block content
  include ../layout
  
  link(href="/css/reports.css" rel="stylesheet")
  
  main.dashboard-container
    .dashboard-header
      .header-content
        div
          h1 Analytics Dashboard
          p Track system performance and complaint trends
          //- p Welcome, #{user.fullname || user.name} (Coordinator)

        .dashboard-tools
          a.btn-secondary(href="/admin/reports")
            | Reports
          
          a.btn-primary(href="/dashboard/admin/export")
            | Export
    
    br
    // ============ EXECUTIVE SUMMARY CARDS ============
    .stats-grid

      .stat-card.pending
        h3 Pending
        //- span= complaints.filter(c => c.status === "PENDING").length
        span= pending

      .stat-card.assigned
        h3 Assigned
        //- span= complaints.filter(c => c.status === "ASSIGNED").length
        span= assigned
        //- span=  rejected

      .stat-card.progress
        h3 In Progress
        //- span= complaints.filter(c => c.status === "IN_PROGRESS").length
        span= inProgress

      .stat-card.resolved
        h3 Resolved
        //- span= complaints.filter(c => c.status === "RESOLVED").length
        span= resolved

