//- extends ../layout

block content
  include ../layout
  
  main.dashboard-container
    .dashboard-header
      .header-content
        div
          h1 Staff Dashboard
          p Welcome, #{user.fullname || user.name} (Department: #{user.department ? user.department.name : 'General'})
    br
    .stats-grid
      .stat-card.pending
        h3 Pending
        span= complaints.filter(c => c.status === "PENDING").length

      .stat-card.assigned
        h3 Assigned
        span= complaints.filter(c => c.status === "ASSIGNED").length

      .stat-card.progress
        h3 In Progress
        span= complaints.filter(c => c.status === "IN_PROGRESS").length

      .stat-card.resolved
        h3 Resolved
        span= complaints.filter(c => c.status === "RESOLVED").length

    .table-card
      .table-header
        .table-title-group
          h2 Assigned Complaints
          p.record-count= complaints.length + " Records"
        .actions
          a.btn-primary(href="/complaints/new") File New Complaint

    
      form(method="GET" action="/dashboard")
        .table-tools
          .tools-search
            i.lucide-relative(data-lucide="search" style="left: 2.4rem; z-index: 1;")
            input.search-input(
              type="search"
              name="search"
              value=filters.query.search || ""
              placeholder="Search complaint..."
            )

          select(name="status")
            option(value="") All Statuses
            each s in filters.statuses
              option(value=s selected=filters.query.status === s)= s

          select(name="priority")
            option(value="") All Priorities
            each p in filters.priorities
              option(value=p selected=filters.query.priority === p)= p

          if user.role === "ADMIN" || user.role === "SUPERADMIN"
            select(name="department")
              option(value="") All Departments
              each dept in departments
                option(value=dept.id selected=filters.query.department == dept.id)= dept.name

          select(name="category")
            option(value="") All Categories
            each c in filters.categories
              option(value=c selected=filters.query.category === c)= c

          button.btn-primary(type="submit") Filter
          a.btn-secondary(href="/dashboard") Reset
      br
      .table-responsive
        table.data-table
          thead
            tr
              th ID
              th Reference #
              th Title
              th Category
              th Priority
              th Status
              th Complainant
              th Complainant Contact
              th Location
              //- th Attachment
              th Assigned At
              th Actions
          tbody
            each complaint in complaints
              tr
                td= complaint.id
                td= complaint.referenceNo
                td= complaint.title
                td= complaint.category
                td
                  span(
                    class=`priority-badge ${complaint.priority.toLowerCase()}`
                  )
                    = complaint.priority

                td

                  span(
                    class=`status-badge ${complaint.status.toLowerCase()}`
                  )
                    = complaint.status
                //- td= complaint.priority
                //- td= complaint.status
                td= (complaint.complainant ? (complaint.complainant.fullname || complaint.complainant.name) : 'N/A')
                td= (complaint.complainant ? complaint.complainant.contactNumber : 'N/A')
                td= complaint.barangay + (complaint.subdivisionVillage ? ", " + complaint.subdivisionVillage : "") + (complaint.streetName ? ", " + complaint.streetName : "")
                //- td
                //-   if complaint.attachments
                //-     a(href=complaint.attachmentUrl target="_blank") View
                td= complaint.assignedAt ? new Date(complaint.assignedAt).toLocaleString() : 'N/A'
                td

                  .actions
                    a.action-btn.view(href=`/complaints/${complaint.id}`) Edit
                //- td
                  a(href="/complaints/" + complaint.id) View
                  a(href="/staff/update?complaintId=" + complaint.id) Update Status
                  a(href="/staff/priority?complaintId=" + complaint.id) Change Priority
                  
  include ../partials/toast
  include ../partials/footer
  