// OVERLAY
#overlay.overlay
// RIGHT SIDEBAR (Notifications)
aside#sidebarRight.sidebar-right
  .notif-header
    h3 Notifications
    #closeRightSidebar.notif-close
      i(data-lucide="x")
  .notif-list
    .notif-item.unread
      .notif-icon
        i(data-lucide="circle-check-big")
      .notif-content
        h4 Complaint Resolved
        p Your complaint about the pothole on Main Street has been resolved.
        span.notif-time 2 hours ago
    .notif-item.unread
      .notif-icon
        i(data-lucide="info")
      .notif-content
        h4 New Update
        p There's an update on your water supply complaint.
        span.notif-time 5 hours ago
    .notif-item
      .notif-icon
        i(data-lucide="user-plus")
      .notif-content
        h4 Account Verified
        p Your account has been successfully verified.
        span.notif-time 1 day ago
    .notif-item
      .notif-icon
        i(data-lucide="bell")
      .notif-content
        h4 Welcome to TUGON
        p Thank you for registering with our complaint redress system.
        span.notif-time 3 days ago